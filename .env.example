# Copy to .env.local (not committed). Same variable name as Google AI Studio Gemini templates.
# Used by the Vite app (chat widget). For Railway server-side Messenger replies (Make → /api/make-messenger), set the same name on the server env.
GEMINI_API_KEY=
# Optional override for server-only Gemini (defaults to gemini-2.0-flash).
# GEMINI_MODEL=gemini-2.0-flash

# Optional alternative (still supported):
# VITE_GEMINI_API_KEY=

# Optional: POST JSON leads when the user types an email or Chile mobile (9 XXXX XXXX).
# See docs/crm-google-sheets.md (Google Apps Script → Sheet).
#
# Production / no proxy: full Apps Script web app URL.
# VITE_LEADS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
#
# Local dev (avoids browser CORS to script.google.com): set the same URL here and use the proxy path below.
# LEADS_APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
# VITE_LEADS_WEBHOOK_URL=/api/leads-proxy

# Optional — Meta / Messenger readiness (see docs/meta-messenger-readiness.md).
# VITE_META_APP_ID=
# VITE_MESSENGER_OUTBOX_MODE=log

# ── Meta webhooks (server only — Railway, NOT VITE_) — same /webhook for Messenger + WhatsApp
# META_WEBHOOK_VERIFY_TOKEN=your_random_shared_verify_string
# MESSENGER_VERIFY_TOKEN=         # fallback if META_WEBHOOK_VERIFY_TOKEN unset
# MESSENGER_PAGE_ACCESS_TOKEN=
# MESSENGER_PAGE_ID=          # numeric Page id — fixes Graph error 100/33 with /me/messages
# META_APP_SECRET=
# MESSENGER_AUTO_REPLY=Gracias, recibimos tu mensaje.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_AUTO_REPLY=Hola, gracias por escribirnos.

# Make.com → Railway: HTTP module POST to https://<your-host>/api/make-messenger
# Header: Authorization: Bearer <same value>
# JSON body: { "psid": "<from Messenger bundle>", "text": "<user message>" }
# MAKE_INBOUND_SECRET=
